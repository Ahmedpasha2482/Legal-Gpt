{
  "name": "criminal-law-ai-chatbot",
  "version": "1.0.0",
  "description": "World's Best Criminal Law AI Chatbot for Indian Legal Use Cases",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/server.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "start": "node server/server.js",
    "install-all": "npm install && cd client && npm install",
    "init-docs": "node server/scripts/initializeSystemDocuments.js init",
    "force-docs": "node server/scripts/initializeSystemDocuments.js force",
    "check-health": "node server/scripts/initializeSystemDocuments.js health"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "axios": "^1.6.2",
    "uuid": "^9.0.1",
    "mongoose": "^8.0.3",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^0.1.7",
    "openai": "^4.24.1",
    "@pinecone-database/pinecone": "^1.1.2",
    "tiktoken": "^1.0.10",
    "node-cron": "^3.0.3",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "rate-limiter-flexible": "^5.0.3",
    "gpt-3-encoder": "^1.1.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "criminal-law",
    "ai-chatbot",
    "indian-law",
    "legal-assistant",
    "rag"
  ],
  "author": "Criminal Law AI Team",
  "license": "MIT"
}